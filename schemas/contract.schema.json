{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-contract-registry.dev/schemas/contract.schema.json",
  "title": "Smart Contract Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "category",
    "language",
    "chains",
    "repositoryUrl",
    "docsUrl",
    "summary",
    "learningFocus",
    "trustStatus",
    "verificationStage"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "DEX",
        "Derivatives",
        "Escrow",
        "Lending",
        "Library",
        "NFT",
        "NFT Marketplace",
        "Restaking",
        "Stablecoin",
        "Streaming",
        "Token",
        "Yield Farming"
      ]
    },
    "language": {
      "type": "string",
      "enum": ["Solidity", "Vyper", "Mixed"]
    },
    "chains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repositoryUrl": {
      "type": "string",
      "format": "uri"
    },
    "docsUrl": {
      "type": "string",
      "format": "uri"
    },
    "walkthroughUrl": {
      "type": "string",
      "format": "uri"
    },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 320
    },
    "learningFocus": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "trustStatus": {
      "type": "string",
      "enum": ["researching", "audited", "unaudited", "exploit-history"]
    },
    "verificationStage": {
      "type": "string",
      "enum": ["seeded", "verified"]
    },
    "trustSummary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 420
    },
    "auditReports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["auditor", "reportUrl"],
        "properties": {
          "auditor": {
            "type": "string",
            "minLength": 2
          },
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"
          },
          "reportUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "deploymentAddresses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chain", "address", "sourceUrl"],
        "properties": {
          "chain": {
            "type": "string",
            "minLength": 1
          },
          "address": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "bugBountyUrl": {
      "type": "string",
      "format": "uri"
    },
    "incidentHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "date", "summary", "sourceUrl"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 4
          },
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"
          },
          "summary": {
            "type": "string",
            "minLength": 20,
            "maxLength": 240
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "sourceLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 2
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verificationStage": {
            "const": "verified"
          }
        }
      },
      "then": {
        "required": [
          "trustSummary",
          "auditReports",
          "deploymentAddresses",
          "sourceLinks"
        ],
        "properties": {
          "trustSummary": {
            "type": "string",
            "minLength": 40
          },
          "auditReports": {
            "type": "array",
            "minItems": 1
          },
          "deploymentAddresses": {
            "type": "array",
            "minItems": 1
          },
          "sourceLinks": {
            "type": "array",
            "minItems": 2
          }
        }
      }
    }
  ]
}
